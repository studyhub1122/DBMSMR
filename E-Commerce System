-- i. Display customers who placed orders
SELECT DISTINCT c.* FROM Customer c
JOIN Orders o ON c.Cid = o.Cid;

-- ii. Count order items per order
SELECT o.Oid, COUNT(oi.Pid) AS ItemCount
FROM Orders o
JOIN OrderItem oi ON o.Oid = oi.Oid
GROUP BY o.Oid;

-- iii. Display customer with order details using JOIN
SELECT c.Cname, o.Oid, oi.Pid, oi.Qty
FROM Customer c
JOIN Orders o ON c.Cid = o.Cid
JOIN OrderItem oi ON o.Oid = oi.Oid;

-- iv. Display customers placing more than average number of orders using nested query
SELECT c.Cname, COUNT(o.Oid) AS OrderCount
FROM Customer c
JOIN Orders o ON c.Cid = o.Cid
GROUP BY c.Cid, c.Cname
HAVING COUNT(o.Oid) > (
    SELECT AVG(Cnt) FROM (
        SELECT COUNT(*) AS Cnt FROM Orders GROUP BY Cid
    ) AS Sub
);
