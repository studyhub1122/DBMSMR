CREATE TABLE Customer (
    Cid   INT PRIMARY KEY,
    Cname VARCHAR(50) NOT NULL
);

CREATE TABLE Orders (
    Oid INT PRIMARY KEY,
    Cid INT,
    FOREIGN KEY (Cid) REFERENCES Customer(Cid)
);

CREATE TABLE OrderItem (
    Oid INT,
    Pid INT,
    Qty INT,
    PRIMARY KEY (Oid, Pid),
    FOREIGN KEY (Oid) REFERENCES Orders(Oid)
);

