-- i. Display students with marks > 60
SELECT * FROM Student WHERE Marks > 60;

-- ii. Display class-wise average marks
SELECT c.ClassName, AVG(s.Marks) AS AvgMarks
FROM Class c
JOIN Student s ON c.ClassId = s.ClassId
GROUP BY c.ClassName;

-- iii. Display student with class name using JOIN
SELECT s.Sname, c.ClassName, s.Marks
FROM Student s
JOIN Class c ON s.ClassId = c.ClassId;

-- iv. Display students scoring above class average using nested query
SELECT s.Sname, s.Marks, s.ClassId
FROM Student s
WHERE s.Marks > (
    SELECT AVG(Marks) FROM Student s2 WHERE s2.ClassId = s.ClassId
);
