CREATE TABLE Class (
    ClassId   INT PRIMARY KEY,
    ClassName VARCHAR(50) NOT NULL
);

CREATE TABLE Student (
    Sid     INT PRIMARY KEY,
    Sname   VARCHAR(50) NOT NULL,
    ClassId INT,
    Marks   INT,
    FOREIGN KEY (ClassId) REFERENCES Class(ClassId)
);

