-- i. Display restaurants having orders above 1000
SELECT DISTINCT r.* FROM Restaurant r
JOIN Orders o ON r.Rid = o.Rid
WHERE o.Amount > 1000;

-- ii. Display total revenue per restaurant
SELECT r.Rname, SUM(o.Amount) AS TotalRevenue
FROM Restaurant r
JOIN Orders o ON r.Rid = o.Rid
GROUP BY r.Rname;

-- iii. Display restaurant with order amount using JOIN
SELECT r.Rname, o.Oid, o.Amount
FROM Orders o
JOIN Restaurant r ON o.Rid = r.Rid;

-- iv. Display restaurants having revenue above average using nested query
SELECT r.Rname, SUM(o.Amount) AS Revenue
FROM Restaurant r
JOIN Orders o ON r.Rid = o.Rid
GROUP BY r.Rid, r.Rname
HAVING SUM(o.Amount) > (SELECT AVG(TotalAmt) FROM (
    SELECT SUM(Amount) AS TotalAmt FROM Orders GROUP BY Rid
) AS Sub);
