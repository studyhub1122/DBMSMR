CREATE TABLE Restaurant (
    Rid   INT PRIMARY KEY,
    Rname VARCHAR(50) NOT NULL
);

CREATE TABLE Orders (
    Oid    INT PRIMARY KEY,
    Rid    INT,
    Amount DECIMAL(10,2),
    FOREIGN KEY (Rid) REFERENCES Restaurant(Rid)
);

