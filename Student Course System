-- i. Display students from Pune
SELECT * FROM Student WHERE City = 'Pune';

-- ii. Display course-wise student count
SELECT c.Cname, COUNT(e.Sid) AS StudentCount
FROM Course c
LEFT JOIN Enrollment e ON c.Cid = e.Cid
GROUP BY c.Cname;

-- iii. Display student name with course name using JOIN
SELECT s.Sname, c.Cname
FROM Student s
JOIN Enrollment e ON s.Sid = e.Sid
JOIN Course c ON e.Cid = c.Cid;

-- iv. Display students enrolled in "DBMS" using nested query
SELECT Sname FROM Student
WHERE Sid IN (
    SELECT Sid FROM Enrollment
    WHERE Cid = (SELECT Cid FROM Course WHERE Cname = 'DBMS')
);
