CREATE TABLE Student (
    Sid   INT PRIMARY KEY,
    Sname VARCHAR(50) NOT NULL,
    City  VARCHAR(50)
);

CREATE TABLE Course (
    Cid   INT PRIMARY KEY,
    Cname VARCHAR(50) NOT NULL UNIQUE
);

CREATE TABLE Enrollment (
    Sid  INT,
    Cid  INT,
    Year INT,
    PRIMARY KEY (Sid, Cid),
    FOREIGN KEY (Sid) REFERENCES Student(Sid),
    FOREIGN KEY (Cid) REFERENCES Course(Cid)
);

