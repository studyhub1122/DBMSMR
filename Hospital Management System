CREATE TABLE Patient (
    Pid   INT PRIMARY KEY,
    Pname VARCHAR(50) NOT NULL,
    Age   INT NOT NULL
);

CREATE TABLE Doctor (
    Did            INT PRIMARY KEY,
    Dname          VARCHAR(50) NOT NULL,
    Specialization VARCHAR(50)
);

CREATE TABLE Visit (
    Pid       INT,
    Did       INT,
    VisitDate DATE,
    PRIMARY KEY (Pid, Did, VisitDate),
    FOREIGN KEY (Pid) REFERENCES Patient(Pid),
    FOREIGN KEY (Did) REFERENCES Doctor(Did)
);

