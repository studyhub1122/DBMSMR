-- i. Display patients above age 50
SELECT * FROM Patient WHERE Age > 50;

-- ii. Count patients per doctor
SELECT d.Dname, COUNT(v.Pid) AS PatientCount
FROM Doctor d
LEFT JOIN Visit v ON d.Did = v.Did
GROUP BY d.Dname;

-- iii. Display patient name with doctor name using JOIN
SELECT p.Pname, d.Dname, v.VisitDate
FROM Visit v
JOIN Patient p ON v.Pid = p.Pid
JOIN Doctor d ON v.Did = d.Did;

-- iv. Display patients treated by doctors with specialization "Cardiology"
SELECT * FROM Patient
WHERE Pid IN (
    SELECT Pid FROM Visit
    WHERE Did IN (
        SELECT Did FROM Doctor WHERE Specialization = 'Cardiology'
    )
);
