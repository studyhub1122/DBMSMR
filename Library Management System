CREATE TABLE Book (
    Bid   INT PRIMARY KEY,
    Title VARCHAR(100) NOT NULL,
    Price DECIMAL(8,2),
    Dept  VARCHAR(50)
);

CREATE TABLE Member (
    Mid   INT PRIMARY KEY,
    Mname VARCHAR(50) NOT NULL
);

CREATE TABLE Issue (
    Bid       INT,
    Mid       INT,
    IssueDate DATE,
    PRIMARY KEY (Bid, Mid),
    FOREIGN KEY (Bid) REFERENCES Book(Bid),
    FOREIGN KEY (Mid) REFERENCES Member(Mid)
);

