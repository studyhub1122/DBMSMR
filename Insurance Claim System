-- i. Display claims above 10000
SELECT * FROM Claim WHERE Amount > 10000;

-- ii. Display total claim amount per customer
SELECT c.Cname, SUM(cl.Amount) AS TotalClaim
FROM Customer c
JOIN Policy p ON c.Cid = p.Cid
JOIN Claim cl ON p.Pid = cl.Pid
GROUP BY c.Cname;

-- iii. Display customer with policy and claim using JOIN
SELECT c.Cname, p.Premium, cl.Amount AS ClaimAmount
FROM Customer c
JOIN Policy p ON c.Cid = p.Cid
JOIN Claim cl ON p.Pid = cl.Pid;

-- iv. Display customers whose claim amount is above average using nested query
SELECT DISTINCT c.Cname
FROM Customer c
JOIN Policy p ON c.Cid = p.Cid
JOIN Claim cl ON p.Pid = cl.Pid
WHERE cl.Amount > (SELECT AVG(Amount) FROM Claim);

