CREATE TABLE Movie (
    Mid   INT PRIMARY KEY,
    Mname VARCHAR(100) NOT NULL,
    Year  INT
);

CREATE TABLE Booking (
    Bid    INT PRIMARY KEY,
    Mid    INT,
    Amount DECIMAL(10,2),
    FOREIGN KEY (Mid) REFERENCES Movie(Mid)
);

