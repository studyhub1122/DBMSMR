-- i. Display movies released after 2020
SELECT * FROM Movie WHERE Year > 2020;

-- ii. Count bookings per movie
SELECT m.Mname, COUNT(b.Bid) AS BookingCount
FROM Movie m
LEFT JOIN Booking b ON m.Mid = b.Mid
GROUP BY m.Mname;

-- iii. Display movie with booking details using JOIN
SELECT m.Mname, b.Bid, b.Amount
FROM Booking b
JOIN Movie m ON b.Mid = m.Mid;

-- iv. Display movies having bookings above average using nested query
SELECT m.Mname, COUNT(b.Bid) AS BookingCount
FROM Movie m
JOIN Booking b ON m.Mid = b.Mid
GROUP BY m.Mid, m.Mname
HAVING COUNT(b.Bid) > (SELECT AVG(Cnt) FROM (
    SELECT COUNT(*) AS Cnt FROM Booking GROUP BY Mid
) AS Sub);
